# Edge server the app talks to over the LAN (kiosk + supervisor share it).
VITE_MES_EDGE_URL=http://localhost:8080

# Cloud server for the supervisor copilot (M13). Optional; when unset or
# unreachable the copilot panel shows an "unavailable offline" banner (§11).
VITE_MES_CLOUD_URL=http://localhost:8081
